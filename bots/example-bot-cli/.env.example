# Copy this file to .env and fill in your values.

# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-your-app-token

# Bot name — must match the bot's directory name under bots/
BOT_NAME=your-bot-name

# Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Skip permission prompts (default: false; true adds --dangerously-skip-permissions
# and launches scripts/auto-approve.sh as a background watcher)
BOT_SKIP_PERMISSION=false

# Auto-commit knowledge/docs/log edits (default: true)
AUTO_COMMIT=true
