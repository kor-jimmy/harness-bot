# Copy this file to .env and fill in your values.
# Each bot reads this file automatically via Bun's built-in .env loader.

# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-your-app-token

# Bot name — used as the MCP channel identifier
BOT_NAME=engineer

# Dashboard port (default: 3001)
# DASHBOARD_PORT=3001

# Harness root directory (default: auto-detected)
# HARNESS_ROOT=/path/to/harness-bot
