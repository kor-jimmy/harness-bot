# harness-bot — root .env
# Copy this file to .env and fill in values. Per-bot tokens live in
# bots/<name>/.env, not here — this file is for harness-wide settings only.

# Optional: Slack Incoming Webhook URL for watchdog alerts.
# Posted whenever the watchdog has to restart a crashed bot.
# Leave blank to disable.
ALERT_WEBHOOK_URL=

# Dashboard port (default: 3001)
# DASHBOARD_PORT=3001
